    </inertial>
  </link>
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.08" length="0.05" />
      </geometry>
      <material name="black" />
    </visual>
