<?xml version="1.0"?>
<robot name="pickplace_rl_mobile" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Materials -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <link name="dummy_root"/>
  
  <joint name="dummy_joint" type="fixed">
    <parent link="dummy_root"/>
    <child link="base_link"/>
  </joint>

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <!-- Sleek beveled chassis look -->
        <box size="0.45 0.35 0.08"/>
      </geometry>
      <material name="white"/>
    </visual>
    <!-- Add some top details for aesthetics -->
    <visual>
      <origin xyz="0 0 0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.3 0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.45 0.35 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <!-- Larger, wider wheel for better look -->
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <!-- Hubcap visual -->
    <visual>
      <origin xyz="0 0.026 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <!-- Hubcap visual -->
    <visual>
      <origin xyz="0 -0.026 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Wheel Joints -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Positioned wider and slightly forward -->
    <origin xyz="0.1 0.205 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.1 -0.205 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Arm Base -->
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <!-- Conical stylised base -->
        <cylinder radius="0.06" length="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <!-- Position offset to back of chassis for balance -->
    <origin xyz="-0.1 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Arm Link 1 (Shoulder) -->
  <link name="arm_link1">
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <!-- Angled sophisticated arm link -->
      <geometry>
        <box size="0.06 0.08 0.24"/>
      </geometry>
      <material name="white"/>
    </visual>
    <!-- Joint cap aesthetic -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.09"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.08 0.24"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="arm_base"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <!-- Arm Link 2 (Upper Arm) -->
  <link name="arm_link2">
    <visual>
      <origin xyz="0.12 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 0.06 0.06"/>
      </geometry>
      <material name="white"/>
    </visual>
    <!-- joint detail -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.07"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0.12 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 0.06 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="shoulder_pitch_joint" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0.24" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="2"/>
  </joint>

  <!-- Arm Link 3 (Forearm) -->
  <link name="arm_link3">
    <visual>
      <origin xyz="0.1 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.04 0.04"/>
      </geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="arm_link2"/>
    <child link="arm_link3"/>
    <origin xyz="0.24 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.35" upper="2.35" effort="8" velocity="2"/>
  </joint>

  <!-- Wrist Link -->
  <link name="wrist_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wrist_roll_joint" type="revolute">
    <parent link="arm_link3"/>
    <child link="wrist_link"/>
    <origin xyz="0.2 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="5" velocity="3"/>
  </joint>

  <!-- End Effector (Gripper Base) -->
  <link name="ee_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.08 0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.08 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="wrist_link"/>
    <child link="ee_link"/>
    <origin xyz="0.03 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="3"/>
  </joint>

  <!-- Left Gripper Finger -->
  <link name="left_finger">
    <visual>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Sleek finger tip -->
        <box size="0.04 0.015 0.06"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <!-- Add an orange gripper pad -->
    <visual>
      <origin xyz="0.02 -0.008 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.002 0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.015 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Right Gripper Finger -->
  <link name="right_finger">
    <visual>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.015 0.06"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin xyz="0.02 0.008 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.002 0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.015 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Gripper Joints -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="ee_link"/>
    <child link="left_finger"/>
    <origin xyz="0.02 0.03 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.01" upper="0.03" effort="5" velocity="0.1"/>
  </joint>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="ee_link"/>
    <child link="right_finger"/>
    <origin xyz="0.02 -0.03 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.01" upper="0.03" effort="5" velocity="0.1"/>
  </joint>

  <!-- Camera Link -->
  <link name="camera_link">
    <!-- Camera housing -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.1 0.04"/>
      </geometry>
      <material name="white"/>
    </visual>
    <!-- Camera lens -->
    <visual>
      <origin xyz="0.021 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.005"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.1 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Positioned elegantly at front center looking down -->
    <origin xyz="0.22 0 0.05" rpy="0 0.3 0"/>
  </joint>

  <!-- Camera Optical Frame -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Gazebo Harmonic Plugins -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.33</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
    
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>shoulder_joint</joint_name>
      <joint_name>shoulder_pitch_joint</joint_name>
      <joint_name>elbow_joint</joint_name>
      <joint_name>wrist_roll_joint</joint_name>
      <joint_name>wrist_pitch_joint</joint_name>
      <joint_name>left_finger_joint</joint_name>
      <joint_name>right_finger_joint</joint_name>
    </plugin>

    <!-- Arm Joint Controllers -->
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>shoulder_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>shoulder_joint/cmd_vel</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>shoulder_pitch_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>shoulder_pitch_joint/cmd_vel</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>elbow_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>elbow_joint/cmd_vel</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>wrist_roll_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>wrist_roll_joint/cmd_vel</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>wrist_pitch_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>wrist_pitch_joint/cmd_vel</topic>
    </plugin>
    
    <!-- Gripper Controllers -->
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>left_finger_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>left_finger_joint/cmd_vel</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>right_finger_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
      <topic>right_finger_joint/cmd_vel</topic>
    </plugin>
  </gazebo>

  <!-- LiDAR Link -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- Mounted on top center of chassis -->
    <origin xyz="0.0 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- Camera Plugin (RGB) -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <update_rate>30.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
      <camera>
        <horizontal_fov>1.047198</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>3</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Depth Camera Plugin (RGB-D) -->
  <gazebo reference="camera_link">
    <sensor name="depth_camera" type="depth_camera">
      <update_rate>15.0</update_rate>
      <always_on>true</always_on>
      <visualize>false</visualize>
      <topic>camera/depth</topic>
      <camera>
        <horizontal_fov>1.047198</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>3</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- 2D LiDAR Plugin for Nav2 -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <update_rate>10.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>scan</topic>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>

</robot>